<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">
  <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-blue-600">
        <i class="fas fa-brain"></i> Qi Learning
      </h1>
      <p class="text-gray-600 mt-2">Verify your identity</p>
    </div>

    <!-- Steps indicator -->
    <div class="flex items-center justify-center mb-6 text-sm">
      <div class="flex items-center">
        <div class="w-7 h-7 rounded-full bg-green-500 text-white flex items-center justify-center font-bold text-xs">
          <i class="fas fa-check text-xs"></i>
        </div>
        <span class="ml-1 text-green-600 font-semibold">Username</span>
      </div>
      <div class="w-8 h-0.5 bg-blue-400 mx-2"></div>
      <div class="flex items-center">
        <div class="w-7 h-7 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-xs">2</div>
        <span class="ml-1 font-semibold text-blue-600">MFA</span>
      </div>
      <div class="w-8 h-0.5 bg-gray-300 mx-2"></div>
      <div class="flex items-center">
        <div class="w-7 h-7 rounded-full bg-gray-200 text-gray-400 flex items-center justify-center font-bold text-xs">3</div>
        <span class="ml-1 text-gray-400">New Password</span>
      </div>
    </div>

    <% if (message && message.length > 0) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <i class="fas fa-exclamation-circle mr-1"></i> <%= message[0] %>
      </div>
    <% } %>

    <div class="text-center mb-6">
      <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-mobile-alt text-blue-600 text-2xl"></i>
      </div>
      <p class="text-gray-600 text-sm">
        Open your authenticator app and enter the 6-digit code for <strong>Qi Learning</strong>.
      </p>
    </div>

    <form action="/auth/forgot-password/mfa" method="POST">
      <div class="mb-6">
        <label class="block text-gray-700 mb-2 text-center" for="token">
          <i class="fas fa-key"></i> MFA Code
        </label>
        <input
          type="text"
          id="token"
          name="token"
          required
          autofocus
          maxlength="6"
          inputmode="numeric"
          autocomplete="one-time-code"
          class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-center text-2xl tracking-widest font-mono"
          placeholder="000000"
        >
      </div>

      <button
        type="submit"
        class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition font-semibold"
      >
        <i class="fas fa-shield-alt"></i> Verify Identity
      </button>
    </form>

    <div class="mt-6 text-center">
      <a href="/auth/forgot-password" class="text-blue-600 hover:underline text-sm">
        <i class="fas fa-arrow-left"></i> Back
      </a>
    </div>
  </div>

  <script>
    // Auto-submit when 6 digits entered
    document.getElementById('token').addEventListener('input', function () {
      if (this.value.length === 6) {
        this.closest('form').submit();
      }
    });
  </script>
</body>
</html>
